APP_NAME="FastAPI SaaS Starter Kit"
APP_ENV="development"
APP_URL="http://localhost:3000"
API_URL="http://localhost:8000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:8000"

DATABASE_URL="postgresql+psycopg://postgres:postgres@db:5432/saas_starter"

SECRET_KEY="change-me-please-with-at-least-32-bytes"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

COOKIE_DOMAIN=""
COOKIE_SECURE=false
COOKIE_SAMESITE="lax"
ACCESS_COOKIE_NAME="saas_access_token"
REFRESH_COOKIE_NAME="saas_refresh_token"
SESSION_COOKIE_NAME="saas_session"
FRONTEND_ORIGINS="http://localhost:3000,http://web:3000"

REDIS_URL="redis://redis:6379/0"
LOG_LEVEL="INFO"
