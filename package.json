{
  "name": "fastapi-saas-starter-kit",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "docker compose up --build",
    "dev:api": "python -m uvicorn app.main:app --app-dir apps/api --reload --host 0.0.0.0 --port 8000",
    "dev:web": "pnpm --dir apps/web dev",
    "lint": "pnpm --dir apps/web lint",
    "typecheck": "pnpm --dir apps/web typecheck",
    "test:api": "pytest apps/api/tests",
    "test:web": "pnpm --dir apps/web test"
  }
}
